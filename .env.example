# Base de datos
DB_NAME=cuentasmexico
DB_USER=root
DB_PASSWORD=tu_contraseña
DB_HOST=localhost
DB_PORT=3306

# Backblaze B2
BACKBLAZE_KEY_ID=tu_key_id
BACKBLAZE_APP_KEY=tu_app_key
BACKBLAZE_BUCKET_NAME=nombre_del_bucket
BACKBLAZE_BUCKET_URL=https://tu_bucket_url.backblazeb2.com

# Django
DEBUG=True
SECRET_KEY=tu_secret_key_aqui
SITE_URL=https://www.cuentasmexico.com

# Email
EMAIL_HOST=tu_host
EMAIL_PORT=465
EMAIL_HOST_USER=tu_email
EMAIL_HOST_PASSWORD=tu_contraseña

# Resend (para notificaciones de stock)
RESEND_API_KEY=re_xxxxxxxxxx
ADMIN_EMAIL=eric@fadetechs.com

# Stripe
STRIPE_PUBLISHABLE_KEY=tu_key_publica
STRIPE_SECRET_KEY=tu_secret_key

# Flow
FLOW_CUSTOMER_KEY=tu_customer_key
FLOW_SECRET_KEY=tu_secret_key

# MercadoPago
MP_ACCESS_TOKEN=tu_access_token_mercadopago
MP_WEBHOOK_SECRET=tu_webhook_secret

# iFrame Token
IFRAME_ACCESS_TOKEN=tu_token

# ============================================
# IA (OpenAI / Gemini)
# ============================================
# Proveedor activo global: openai | gemini
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL_TEXT=gpt-5.4
OPENAI_MODEL_HYBRID=gpt-5.4
OPENAI_MODEL_IMAGE=gpt-image-1.5
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-mini-transcribe
OPENAI_MODEL_SPEECH=gpt-4o-mini-tts

# Gemini
GEMINI_API_KEY=AIzaSyxxxx
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_TEXT=gemini-3-flash-preview
GEMINI_MODEL_HYBRID=gemini-3-flash-preview
GEMINI_MODEL_IMAGE=gemini-2.5-flash-image
GEMINI_MODEL_TRANSCRIPTION=gemini-2.5-flash
GEMINI_MODEL_SPEECH=gemini-2.5-flash-preview-tts

# MCP DB IA (solo lectura)
AI_DB_ALLOWED_TABLES=auth_user,adm_sale,adm_userdetail,adm_account,adm_business,adm_service
AI_DB_MAX_ROWS=200
AI_DB_INCLUDE_SCHEMA=true

# Chat flotante IA
AI_CHAT_ENABLED=true
AI_CHAT_MAX_MESSAGE_CHARS=4000
AI_CHAT_MAX_IMAGES=3
AI_CHAT_MAX_IMAGE_MB=4
AI_CHAT_HISTORY_TURNS=4
AI_CHAT_MAX_OUTPUT_TOKENS=900
AI_CHAT_TEMPERATURE=0.2
AI_CHAT_TIMEOUT_SEC=25
AI_CHAT_RATE_LIMIT=20
AI_CHAT_RATE_WINDOW_SEC=60
AI_CHAT_USE_DB_CONTEXT=true
AI_CHAT_SYSTEM_PROMPT=Eres un asistente útil para clientes de Cuentas México. Responde de forma clara y breve.
